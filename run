#!/bin/bash

###############################################################################
# Spring Boot JAR Runner Script
# Usage: ./run-app.sh [OPTIONS] <jar-file-path>
# Example: ./run-app.sh -e prod -l ./logs build/libs/myapp.jar
###############################################################################

set -e  # Exit on error

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

###############################################################################
# Functions
###############################################################################

print_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

print_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_debug() {
    if [ "$DEBUG" = true ]; then
        echo -e "${BLUE}[DEBUG]${NC} $1"
    fi
}

show_usage() {
    cat << EOF
Usage: $0 [OPTIONS] <jar-file-path>

Options:
  -e, --environment ENV    Environment profile (local|dev|prod) [default: local]
  -l, --log-dir DIR        Log directory path [default: ./logs]
  -m, --memory SIZE        Maximum heap memory (e.g., 2g, 512m) [default: env-specific]
  -g, --gc TYPE            GC algorithm (g1|zgc|parallel) [default: env-specific]
  -p, --port PORT          Debug port for local/dev environment [default: 5005]
  -j, --jmx-port PORT      JMX port for prod environment [default: 9010]
  -d, --debug              Enable debug output
  -h, --help               Show this help message
  --heap-dump              Enable heap dump on OOM [default: enabled]
  --no-heap-dump           Disable heap dump on OOM
  --gc-log                 Enable GC logging [default: enabled in prod]
  --no-gc-log              Disable GC logging
  --confirm                Skip confirmation prompt in prod

Arguments:
  jar-file-path            Path to the Spring Boot JAR file

Environment Profiles:
  local        Local development (fastest startup, minimal monitoring)
  dev          Development server (with debugging, moderate resources)
  prod         Production server (optimized performance, full monitoring)

Examples:
  # Start with default local settings
  $0 build/libs/myapp.jar

  # Start in development mode
  $0 -e dev build/libs/myapp.jar

  # Start in production mode
  $0 -e prod build/libs/myapp.jar

  # Custom memory and log directory
  $0 -e prod -m 4g -l /var/log/myapp build/libs/myapp.jar

  # Use ZGC with custom JMX port
  $0 -e prod -g zgc -j 9020 build/libs/myapp.jar

  # Local with custom debug port
  $0 -e local -p 5006 build/libs/myapp.jar

EOF
    exit 1
}

###############################################################################
# Default values
###############################################################################

ENVIRONMENT="local"
LOG_DIR="./logs"
MEMORY=""
GC_TYPE=""
DEBUG_PORT="5005"
JMX_PORT="9010"
DEBUG=false
HEAP_DUMP=true
GC_LOG=""
SKIP_CONFIRM=false

###############################################################################
# Parse arguments
###############################################################################

POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        -e|--environment)
            ENVIRONMENT="$2"
            shift 2
            ;;
        -l|--log-dir)
            LOG_DIR="$2"
            shift 2
            ;;
        -m|--memory)
            MEMORY="$2"
            shift 2
            ;;
        -g|--gc)
            GC_TYPE="$2"
            shift 2
            ;;
        -p|--port)
            DEBUG_PORT="$2"
            shift 2
            ;;
        -j|--jmx-port)
            JMX_PORT="$2"
            shift 2
            ;;
        -d|--debug)
            DEBUG=true
            shift
            ;;
        --heap-dump)
            HEAP_DUMP=true
            shift
            ;;
        --no-heap-dump)
            HEAP_DUMP=false
            shift
            ;;
        --gc-log)
            GC_LOG=true
            shift
            ;;
        --no-gc-log)
            GC_LOG=false
            shift
            ;;
        --confirm)
            SKIP_CONFIRM=true
            shift
            ;;
        -h|--help)
            show_usage
            ;;
        -*|--*)
            print_error "Unknown option: $1"
            show_usage
            ;;
        *)
            POSITIONAL_ARGS+=("$1")
            shift
            ;;
    esac
done

# Restore positional parameters
set -- "${POSITIONAL_ARGS[@]}"

###############################################################################
# Validate arguments
###############################################################################

if [ $# -eq 0 ]; then
    print_error "JAR file path is required"
    show_usage
fi

JAR_FILE="$1"

# Check if JAR file exists
if [ ! -f "$JAR_FILE" ]; then
    print_error "JAR file not found: $JAR_FILE"
    exit 1
fi

# Convert to absolute path
JAR_FILE=$(realpath "$JAR_FILE")

# Validate environment
case "$ENVIRONMENT" in
    local|dev|development|prod|production)
        # Valid environment
        ;;
    *)
        print_error "Invalid environment: $ENVIRONMENT"
        print_error "Supported environments: local, dev, prod"
        exit 1
        ;;
esac

# Normalize environment names
case "$ENVIRONMENT" in
    development) ENVIRONMENT="dev" ;;
    production) ENVIRONMENT="prod" ;;
esac

# Validate GC type if specified
if [ -n "$GC_TYPE" ]; then
    case "$GC_TYPE" in
        g1|zgc|parallel)
            # Valid GC type
            ;;
        *)
            print_error "Invalid GC type: $GC_TYPE"
            print_error "Supported GC types: g1, zgc, parallel"
            exit 1
            ;;
    esac
fi

# Create log directory
mkdir -p "$LOG_DIR"
LOG_DIR=$(realpath "$LOG_DIR")

print_debug "JAR File: $JAR_FILE"
print_debug "Environment: $ENVIRONMENT"
print_debug "Log Directory: $LOG_DIR"

###############################################################################
# Set environment-specific defaults
###############################################################################

# Set default memory if not specified
if [ -z "$MEMORY" ]; then
    case "$ENVIRONMENT" in
        local)
            MEMORY="1g"
            INITIAL_MEMORY="256m"
            ;;
        dev)
            MEMORY="2g"
            INITIAL_MEMORY="512m"
            ;;
        prod)
            MEMORY="4g"
            INITIAL_MEMORY="4g"  # Fixed size for prod
            ;;
    esac
else
    case "$ENVIRONMENT" in
        prod)
            INITIAL_MEMORY="$MEMORY"  # Fixed size for prod
            ;;
        *)
            # For local/dev, use smaller initial memory
            INITIAL_MEMORY="${MEMORY%g}g"
            if [[ "$MEMORY" =~ ^([0-9]+)g$ ]]; then
                local mem_gb="${BASH_REMATCH[1]}"
                local initial_gb=$((mem_gb / 4))
                if [ $initial_gb -lt 1 ]; then
                    initial_gb=1
                fi
                INITIAL_MEMORY="${initial_gb}g"
            else
                INITIAL_MEMORY="$MEMORY"
            fi
            ;;
    esac
fi

# Set default GC if not specified
if [ -z "$GC_TYPE" ]; then
    case "$ENVIRONMENT" in
        local)
            GC_TYPE="g1"
            ;;
        dev)
            GC_TYPE="g1"
            ;;
        prod)
            GC_TYPE="zgc"
            ;;
    esac
fi

# Set default GC log behavior if not specified
if [ -z "$GC_LOG" ]; then
    case "$ENVIRONMENT" in
        prod)
            GC_LOG=true
            ;;
        *)
            GC_LOG=false
            ;;
    esac
fi

###############################################################################
# Build JVM options
###############################################################################

# Common options
COMMON_OPTS=(
    "-Dfile.encoding=UTF-8"
    "-Djava.awt.headless=true"
)

# Memory options
JVM_OPTS=(
    "-Xms${INITIAL_MEMORY}"
    "-Xmx${MEMORY}"
)

# GC options
case "$GC_TYPE" in
    g1)
        JVM_OPTS+=(
            "-XX:+UseG1GC"
        )
        if [ "$ENVIRONMENT" = "local" ]; then
            JVM_OPTS+=(
                "-XX:TieredStopAtLevel=1"  # Fastest startup for local
            )
        fi
        ;;
    zgc)
        JVM_OPTS+=(
            "-XX:+UseZGC"
            "-XX:+UseStringDeduplication"
            "-XX:+AlwaysPreTouch"
        )
        ;;
    parallel)
        JVM_OPTS+=(
            "-XX:+UseParallelGC"
        )
        ;;
esac

# Heap dump options
if [ "$HEAP_DUMP" = true ]; then
    TIMESTAMP=$(date +%Y%m%d-%H%M%S)
    JVM_OPTS+=(
        "-XX:+HeapDumpOnOutOfMemoryError"
        "-XX:HeapDumpPath=${LOG_DIR}/heapdump-${ENVIRONMENT}-${TIMESTAMP}.hprof"
    )
fi

# Environment-specific options
case "$ENVIRONMENT" in
    local)
        JVM_OPTS+=(
            # Fast startup
            "-XX:TieredStopAtLevel=1"

            # Remote debugging
            "-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:${DEBUG_PORT}"

            # Spring profile
            "-Dspring.profiles.active=local"

            # DevTools
            "-Dspring.devtools.restart.enabled=true"
            "-Dspring.devtools.livereload.enabled=true"
        )
        print_info "Local development mode - optimized for fast startup"
        ;;

    dev)
        JVM_OPTS+=(
            # Remote debugging
            "-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:${DEBUG_PORT}"

            # Spring profile
            "-Dspring.profiles.active=dev"

            # DevTools
            "-Dspring.devtools.restart.enabled=true"

            # Actuator
            "-Dmanagement.endpoints.web.exposure.include=*"
        )
        print_info "Development mode - with debugging and monitoring"
        ;;

    prod)
        JVM_OPTS+=(
            # Server mode
            "-server"

            # Exit on OOM
            "-XX:+ExitOnOutOfMemoryError"

            # Native memory trimming
            "-XX:TrimNativeHeapInterval=30000"

            # JMX monitoring
            "-Dcom.sun.management.jmxremote"
            "-Dcom.sun.management.jmxremote.port=${JMX_PORT}"
            "-Dcom.sun.management.jmxremote.authenticate=false"
            "-Dcom.sun.management.jmxremote.ssl=false"

            # Spring profile
            "-Dspring.profiles.active=prod"

            # Production optimizations
            "-Dspring.jmx.enabled=true"
            "-Dmanagement.endpoints.web.exposure.include=health,info,metrics,prometheus"
        )
        print_info "Production mode - optimized for performance and monitoring"
        ;;
esac

# GC logging
if [ "$GC_LOG" = true ]; then
    TIMESTAMP=$(date +%Y%m%d-%H%M%S)
    GC_LOG_FILE="${LOG_DIR}/gc-${ENVIRONMENT}-${TIMESTAMP}.log"

    # Check Java version for logging syntax
    JAVA_VERSION=$(java -version 2>&1 | head -n 1 | awk -F '"' '{print $2}' | awk -F '.' '{print $1}')

    if [ "$JAVA_VERSION" -ge 9 ]; then
        # Java 9+ unified logging
        JVM_OPTS+=(
            "-Xlog:gc*:file=${GC_LOG_FILE}:time,uptime,level,tags"
        )
    else
        # Java 8 style logging
        JVM_OPTS+=(
            "-Xloggc:${GC_LOG_FILE}"
            "-XX:+PrintGCDetails"
            "-XX:+PrintGCDateStamps"
        )
    fi
fi

###############################################################################
# Display configuration
###############################################################################

echo ""
print_info "=========================================="
print_info "Spring Boot Application Runner"
print_info "=========================================="
print_info "JAR File    : $JAR_FILE"
print_info "Environment : $ENVIRONMENT"
print_info "Memory      : ${INITIAL_MEMORY} - ${MEMORY}"
print_info "GC Type     : $GC_TYPE"
print_info "Log Dir     : $LOG_DIR"
print_info "Java Version: $(java -version 2>&1 | head -n 1)"

if [ "$ENVIRONMENT" = "local" ] || [ "$ENVIRONMENT" = "dev" ]; then
    print_info "Debug Port  : $DEBUG_PORT"
fi

if [ "$ENVIRONMENT" = "prod" ]; then
    print_info "JMX Port    : $JMX_PORT"
fi

print_info "Heap Dump   : $([ "$HEAP_DUMP" = true ] && echo "Enabled" || echo "Disabled")"
print_info "GC Log      : $([ "$GC_LOG" = true ] && echo "Enabled" || echo "Disabled")"

# Environment-specific info
case "$ENVIRONMENT" in
    local)
        print_info "Features    : Fast startup, DevTools, LiveReload"
        ;;
    dev)
        print_info "Features    : Remote debugging, Full actuator endpoints"
        ;;
    prod)
        print_info "Features    : JMX monitoring, Production endpoints only"
        ;;
esac

print_info "=========================================="

# Display JVM options in debug mode
if [ "$DEBUG" = true ]; then
    print_debug "JVM Options:"
    for opt in "${COMMON_OPTS[@]}" "${JVM_OPTS[@]}"; do
        echo "  $opt"
    done
    print_debug "=========================================="
fi

# Confirmation prompt for production
if [ "$ENVIRONMENT" = "prod" ] && [ "$SKIP_CONFIRM" = false ]; then
    echo ""
    print_warn "You are about to start the application in PRODUCTION mode."
    read -p "Continue? (y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        print_info "Aborted."
        exit 0
    fi
fi

###############################################################################
# Execute
###############################################################################

echo ""
print_info "Starting application..."
echo ""

# Combine all options
ALL_OPTS=("${COMMON_OPTS[@]}" "${JVM_OPTS[@]}")

# Execute
exec java "${ALL_OPTS[@]}" -jar "$JAR_FILE"

# exec replaces the process, so nothing after this line will execute
